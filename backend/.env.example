PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mahalxmi_tailors
JWT_SECRET=your_jwt_secret_key_here

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Cloudinary Config (Optional, for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS SES Config (Optional, for emails)
SES_FROM_NAME=Mahalaxmi Tailors
SES_FROM_EMAIL=noreply@mahalaxmitailors.com
CONTACT_EMAIL=support@mahalaxmitailors.com

AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1

# CORS configuration for frontend
FRONTEND_URL=your_amplify_frontend_url_here
